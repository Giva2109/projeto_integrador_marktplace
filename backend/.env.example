# =========
# Backend (FastAPI) - Exemplo de variáveis de ambiente
# Preencha os valores no arquivo `.env` (NÃO commitar).
# =========

# --- App (nome exibido no OpenAPI / documentação; alinhado ao repo projeto-integrador-mercado-livre) ---
APP_ENV=dev
APP_NAME=Projeto Integrador Mercado Livre

# --- Supabase (obrigatório para backend) ---
# Settings -> API -> Project URL
SUPABASE_URL=

# Settings -> API -> service_role (SOMENTE backend)
SUPABASE_SERVICE_ROLE_KEY=

# Settings -> API -> anon (opcional no backend; útil para testes/clients com RLS)
SUPABASE_ANON_KEY=

# (Opcional) Audience esperada ao validar JWT do Supabase via JWKS.
# Geralmente: authenticated
SUPABASE_JWT_AUD=authenticated

# (Opcional) String de conexão direta com Postgres (não usada pelo código atual).
DATABASE_URL=

# --- Segredos internos do backend ---
# Usado para criptografar tokens OAuth antes de salvar no Supabase (NÃO troque após tokens já gravados).
TOKEN_CRYPTO_SECRET=

# --- Mercado Livre OAuth (obrigatório para integração Meli) ---
MELI_CLIENT_ID=
MELI_CLIENT_SECRET=

# Deve ser idêntico ao Redirect URI cadastrado no app do Mercado Livre.
# Ex: http://127.0.0.1:8080/oauth/meli/callback (local) ou https://<app>.fly.dev/oauth/meli/callback (prod)
MELI_REDIRECT_URI=

# --- Shopee OAuth (placeholder; ainda não usado) ---
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_REDIRECT_URI=

